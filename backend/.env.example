# ASTRA Configuration
# Copy this to .env and fill in your values

# Ollama Configuration

# Optional: Remote GPU host (only if you have a remote Ollama server)
# GPU_HOST=http://your-gpu-server:11434

# App Settings
FLASK_PORT=5050
FLASK_DEBUG=False

# Voice Settings
VOICE_ENABLED=True
VOICE_RATE=175
VOICE_VOLUME=1.0

# Memory Settings
MEMORY_FILE=memory.json
MAX_HISTORY=50

# TTS Provider: pyttsx3 | kokoro | elevenlabs
TTS_PROVIDER=pyttsx3
# ELEVENLABS_API_KEY=your_key_here

# Search Settings
SEARCH_ENABLED=True
MAX_SEARCH_RESULTS=5

# Ollama Host
OLLAMA_HOST=http://localhost:11434

# Redis
REDIS_URL=redis://localhost:6379

# Optional API Keys
SERPER_API_KEY=
PICOVOICE_API_KEY=

# Models
DEFAULT_MODEL=phi3:mini
VISION_MODEL=llava:7b
RESEARCH_MODEL=llama3.2:3b
TECHNICAL_MODEL=mistral

# Code execution safety gate (default off)
ALLOW_CODE_EXECUTION=false

# Wake word model override (filename in wake_models/ or absolute path)
# Leave blank for auto-detect based on platform
# WAKE_WORD_MODEL=Hey-ASTRA_en_mac_v4_0_0.ppn

# Cache Settings (optional overrides)
CACHE_TTL_SECONDS=600
CACHE_MAX_WORDS=200
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET_KEY=REPLACE_WITH: python3 -c "import secrets; print(secrets.token_hex(32))"
