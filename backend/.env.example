# ASTRA Configuration
# Copy this to .env and fill in your values

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# Optional: Remote GPU host (only if you have a remote Ollama server)
# GPU_HOST=http://your-gpu-server:11434

# App Settings
FLASK_PORT=5050
FLASK_DEBUG=False

# Voice Settings
VOICE_ENABLED=True
VOICE_RATE=175
VOICE_VOLUME=1.0

# Memory Settings
MEMORY_FILE=memory.json
MAX_HISTORY=50

# TTS Provider: pyttsx3 | kokoro | elevenlabs
TTS_PROVIDER=pyttsx3
# ELEVENLABS_API_KEY=your_key_here

# Search Settings
SEARCH_ENABLED=True
MAX_SEARCH_RESULTS=5

# Ollama Host
OLLAMA_HOST=http://localhost:11434

# Redis
REDIS_URL=redis://localhost:6379

# Optional API Keys
SERPER_API_KEY=
PICOVOICE_API_KEY=

# Models
DEFAULT_MODEL=phi3:mini
VISION_MODEL=llava:7b
RESEARCH_MODEL=llama3.2:3b
TECHNICAL_MODEL=mistral
